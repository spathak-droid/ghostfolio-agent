{
  "name": "agent",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/agent/server",
  "projectType": "application",
  "targets": {
    "test": {
      "executor": "@nx/jest:jest",
      "options": {
        "jestConfig": "apps/agent/jest.config.ts"
      },
      "outputs": ["{workspaceRoot}/coverage/apps/agent"]
    },
    "serve": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "command": "npm run build:agent-widget && DOTENV_CONFIG_PATH=.env ts-node apps/agent/server/index.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "eslintConfig": "apps/agent/eslint.config.cjs",
        "lintFilePatterns": ["apps/agent/server/**/*.ts", "apps/agent/widget/**/*.ts"]
      }
    }
  },
  "tags": []
}
