COMPOSE_PROJECT_NAME=ghostfolio

# CACHE (Railway Redis URL)
REDIS_URL=<INSERT_RAILWAY_REDIS_URL>
REDIS_HOST=redis.railway.internal
REDIS_PORT=6379
REDIS_PASSWORD=<INSERT_REDIS_PASSWORD>

# POSTGRES (Railway Postgres URL)
POSTGRES_DB=railway
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<INSERT_POSTGRES_PASSWORD>

# VARIOUS
ACCESS_TOKEN_SALT=<INSERT_RANDOM_STRING>
ADMIN_ID=
DATABASE_URL=<INSERT_RAILWAY_DATABASE_URL>
JWT_SECRET_KEY=<INSERT_RANDOM_STRING>

# API port (default 3333). Set PORT=3334 if 3333 is already in use.
# PORT=3333
# STANDALONE AGENT (LOCAL)
AGENT_PORT=4444
AGENT_SERVICE_URL=http://localhost:4444
AGENT_WIDGET_SCRIPT_URL=http://localhost:4444/widget/index.js
OPENAI_API_KEY=<INSERT_OPENAI_API_KEY>
OPENAI_MODEL=gpt-4o-mini
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=<INSERT_LANGSMITH_API_KEY>
LANGSMITH_PROJECT=ghostfolio-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
